  .footer-links a {
    text-decoration: none;
    color: #90caf9;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
    }

    .footer-links {
      width: 100%;
      justify-content: center;
