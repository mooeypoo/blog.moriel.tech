---
import ThemeToggle from '../components/ThemeToggle.vue'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string
  description?: string
  canonical?: string
}

const {
  title = 'Moriel Writes Tech',
  description = 'A blog about human-centered software development, experiences, thoughts, and learnings.',
  canonical = 'https://blog.moriel.tech'
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="author" content="Moriel Schottlender" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Moriel Writes Tech" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://blog.moriel.tech/moriel-320px.jpg" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@mooeypoo" />
    <meta name="twitter:creator" content="@mooeypoo" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://blog.moriel.tech/moriel-320px.jpg" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Arimo:wght@400;600&family=Inconsolata:wght@400;600;700&family=Merriweather:wght@700&family=Roboto:wght@400;500;700&display=swap"
    />

    <title>{title} - blog.moriel.tech</title>
  </head>
  <body>
    <ThemeToggle client:load />
    
    <main class="page-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #121212;
    --surface: #212121;
    --text: #ffffff;
    --primary: #90caf9;
    --outline: rgba(255, 255, 255, 0.2);
  }

  html.light-theme {
    --bg: #fafafa;
    --surface: #f5f5f5;
    --text: #212121;
    --primary: #1976d2;
    --outline: rgba(0, 0, 0, 0.2);
  }

  html {
    scroll-padding-top: 100px;
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: 'Arimo', sans-serif;
    line-height: 1.6;
    transition: background 0.3s, color 0.3s;
  }

  .page-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
  }

  h1 {
    font-family: 'Merriweather', serif;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
  }

  h2 {
    font-family: 'Merriweather', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem 0;
  }

  h3 {
    font-family: 'Merriweather', serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 1.25rem 0 0.5rem 0;
  }

  p {
    margin: 0 0 1rem 0;
  }

  a {
    color: var(--primary);
    transition: opacity 0.2s;
  }

  a:hover {
    opacity: 0.8;
  }

  button {
    font-family: inherit;
  }

  code {
    font-family: 'Inconsolata', monospace;
  }

  @media (max-width: 640px) {
    .page-content {
      padding: 1.5rem 1rem 2rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    h2 {
      font-size: 1.25rem;
    }
  }
</style>
