---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getPublishedPosts } from '../../lib/content'
import { SITE_URL } from '../../lib/seo'

export async function getStaticPaths() {
  const posts = await getPublishedPosts()
  const tags = new Set<string>()

  for (const post of posts) {
    for (const tag of post.data.tags || []) {
      tags.add(tag)
    }
  }

  return Array.from(tags).map((tag) => ({
    params: { tag: encodeURIComponent(tag) },
    props: { tag, posts },
  }))
}

interface Props {
  tag: string
  posts: Awaited<ReturnType<typeof getPublishedPosts>>
}

const { tag, posts } = Astro.props
const decodedTag = decodeURIComponent(tag)
const filteredPosts = posts.filter((p) => (p.data.tags || []).includes(decodedTag))

const canonical = `${SITE_URL}/tags/${tag}`
const title = `Posts tagged with "${decodedTag}"`
const description = `All posts tagged with ${decodedTag} on Moriel's Blog.`
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="tag-posts-container">
    <h1>Posts tagged <em>#{decodedTag}</em></h1>

    {filteredPosts.length > 0 ? (
      <div class="posts-grid">
        {filteredPosts.map((post) => (
          <article class="post-card" key={post.slug}>
            <h2 class="post-title">
              <a href={`/posts/${post.slug}`}>{post.data.title}</a>
            </h2>
            {post.data.date && (
              <p class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
            )}
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
            <p>
              <a href={`/posts/${post.slug}`} class="read-more">Read more →</a>
            </p>
          </article>
        ))}
      </div>
    ) : (
      <p>No posts found for this tag.</p>
    )}

    <p class="back-link">
      <a href="/tags">← Back to all tags</a>
    </p>
  </section>
</BaseLayout>

<style>
  .tag-posts-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .tag-posts-container h1 {
    word-break: break-word;
  }

  .tag-posts-container em {
    color: var(--primary);
    font-style: normal;
  }

  .posts-grid {
    display: grid;
    gap: 2rem;
    margin: 2rem 0;
  }

  .post-card {
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
  }

  .post-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .post-title a {
    text-decoration: none;
  }

  .post-title a:hover {
    text-decoration: underline;
  }

  .post-date {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .post-desc {
    margin: 0 0 1rem 0;
    line-height: 1.6;
  }

  .read-more {
    text-decoration: none;
  }

  .read-more:hover {
    text-decoration: underline;
  }

  .back-link {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .back-link a {
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }
</style>
